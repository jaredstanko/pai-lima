# PAI-Lima Version Manifest
# Single source of truth for all pinned dependency versions.
# All install scripts source this file. Edit versions here, not in scripts.
#
# To update versions:
#   1. Change the version/SHA below
#   2. Run: ./verify.sh to confirm the new versions work
#   3. Commit the change
#
# Review cadence: monthly (security patches, compatibility)

# ─── Host Tools (macOS / Homebrew) ───────────────────────────
LIMA_MIN_VERSION="1.0.0"
# Homebrew doesn't support exact pinning for most formulae/casks.
# We verify post-install that versions meet minimum requirements.

# ─── Ubuntu Cloud Image ──────────────────────────────────────
UBUNTU_IMAGE_URL="https://cloud-images.ubuntu.com/releases/24.04/release-20250306/ubuntu-24.04-server-cloudimg-arm64.img"
UBUNTU_IMAGE_SHA256="1ea801e659d2f5035ac294e0faab0aac9b6ba66753df933ba5c7beab0c689bd0"
# Pin to a date-stamped release, not the floating "release" symlink.
# SHA256 from: https://cloud-images.ubuntu.com/releases/24.04/release-20250306/SHA256SUMS

# ─── VM Tools ────────────────────────────────────────────────
BUN_VERSION="1.3.11"
CLAUDE_CODE_VERSION="2.1.89"
NODE_MAJOR_VERSION="18"
PLAYWRIGHT_VERSION="1.59.0"

# ─── Git Repos (pinned to commit SHA or tag) ─────────────────
PAI_REPO="https://github.com/danielmiessler/PAI.git"
PAI_COMMIT="HEAD"
# TODO: Pin to specific commit SHA once a stable release is tagged

PAI_COMPANION_REPO="https://github.com/chriscantey/pai-companion.git"
PAI_COMPANION_COMMIT="HEAD"
# TODO: Pin to specific commit SHA once a stable release is tagged

# ─── apt packages (Ubuntu 24.04 noble) ───────────────────────
# These are pinned to major versions available in Ubuntu 24.04.
# Exact patch versions float with Ubuntu point releases, which is acceptable
# since the Ubuntu image itself is pinned above.
APT_PACKAGES="jq fzf ripgrep fd-find sqlite3 tmux bat yt-dlp ffmpeg curl wget imagemagick nmap whois dnsutils net-tools traceroute mtr texlive-latex-base texlive-fonts-recommended pandoc golang-go python3 python3-pip python3-venv build-essential git zip tree nodejs npm kitty-terminfo"
